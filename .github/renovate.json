{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    ":semanticCommits"
  ],
  "timezone": "Europe/Berlin",
  "schedule": ["* 0-6 * * 1"],
  "prConcurrentLimit": 5,
  "prHourlyLimit": 2,
  "minimumReleaseAge": "14 days",
  "internalChecksFilter": "strict",
  "configMigration": true,
  "dependencyDashboard": true,
  "rangeStrategy": "bump",
  "customManagers": [
    {
      "customType": "regex",
      "description": "Keep PHP version in .github/workflows/php-verify.yml in sync with the Dockerfile",
      "managerFilePatterns": ["/^\\.github/workflows/php-verify\\.ya?ml$/"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>.*?) depName=(?<depName>.*?)\\s+php-version:\\s*\\['(?<currentValue>[^']+)'\\]"
      ],
      "versioningTemplate": "docker"
    }
  ],
  "packageRules": [
    {
      "description": "Group PHP version bumps across Dockerfile and the verify workflow into one update",
      "matchPackageNames": ["php"],
      "matchDatasources": ["docker"],
      "groupName": "php version",
      "commitMessageTopic": "PHP"
    },
    {
      "description": "Auto-merge non-major PHP (composer) updates without opening a PR",
      "matchManagers": ["composer"],
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "automerge": true,
      "automergeType": "branch",
      "ignoreTests": false,
      "minimumReleaseAge": "14 days"
    },
    {
      "description": "Open PRs for major PHP (composer) updates - require manual review",
      "matchManagers": ["composer"],
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "labels": ["dependencies", "php", "major-update"],
      "minimumReleaseAge": "14 days"
    },
    {
      "description": "Ignore patch-level Docker updates so images stay pinned to major.minor only",
      "matchManagers": ["dockerfile"],
      "matchUpdateTypes": ["patch"],
      "enabled": false
    },
    {
      "description": "Auto-merge minor Dockerfile base image updates without opening a PR",
      "matchManagers": ["dockerfile"],
      "matchUpdateTypes": ["minor", "pin"],
      "automerge": true,
      "automergeType": "branch",
      "ignoreTests": false,
      "minimumReleaseAge": "14 days"
    },
    {
      "description": "Open PRs for major Dockerfile base image updates",
      "matchManagers": ["dockerfile"],
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "labels": ["dependencies", "docker", "major-update"],
      "minimumReleaseAge": "14 days"
    },
    {
      "description": "Group PHP runtime image updates across both Dockerfile and debug.Dockerfile",
      "matchManagers": ["dockerfile"],
      "matchPackageNames": ["php"],
      "groupName": "php version"
    },
    {
      "description": "Do not pin Docker image digests - keep tags as major.minor only",
      "matchManagers": ["dockerfile"],
      "pinDigests": false
    }
  ],
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security"],
    "minimumReleaseAge": null,
    "automerge": true
  },
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true,
    "schedule": ["* 0-6 * * 1"]
  }
}
